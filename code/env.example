# WindSight 环境变量配置模板
# 推荐用法（本项目默认优先加载）：复制此文件为 windsight.env 并填写实际值
# 说明：
# - app.py 启动时会按优先级加载：WINDSIGHT_ENV_FILE > windsight.env > .env
# - windsight.env / .env 属于本机私有配置文件，避免误提交到仓库

# ==================== 安全配置 ====================
# Flask密钥（生产环境必须修改！）
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# ==================== 默认管理员（首次启动自动创建）====================
# 说明：
# - 未设置 WINDSIGHT_DEFAULT_ADMIN_PASSWORD 时，后端会生成随机密码并打印到日志（更安全）
WINDSIGHT_DEFAULT_ADMIN_ENABLED=1
WINDSIGHT_DEFAULT_ADMIN_USERNAME=WindSight
# WINDSIGHT_DEFAULT_ADMIN_PASSWORD=请设置强密码

# ==================== 数据库配置 ====================
# SQLite（默认）
# 目录结构约定（根目录只保留 code/ 与 database/）：默认指向 ../database/wind_farm.db
DATABASE_URL=sqlite:///../database/wind_farm.db

# PostgreSQL（生产环境推荐）
# DATABASE_URL=postgresql://username:password@localhost:5432/windsight

# ==================== 服务器配置 ====================
# 服务器主机地址
HOST=0.0.0.0

# 服务器端口
PORT=5000

# 调试模式（生产环境必须为False）
DEBUG=False

# ==================== 跨域配置 ====================
# 允许的域名列表（逗号分隔）
# 建议生产环境配置为你的前端域名列表；联调可先用 *
ALLOWED_ORIGINS=*

# ==================== 数据保留配置 ====================
# 历史数据保留天数（0表示永久保存）
DATA_RETENTION_DAYS=30

# ==================== 日志配置 ====================
# 日志级别：DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE=logs/windsight.log

# ==================== 性能配置 ====================
# WebSocket ping间隔（秒）
SOCKET_PING_INTERVAL=10

# WebSocket ping超时（秒）
SOCKET_PING_TIMEOUT=20

# 数据库连接超时（秒）
DB_TIMEOUT=20

# ==================== 用户配置 ====================
# 密码最小长度
PASSWORD_MIN_LENGTH=8

# 是否要求密码包含大写字母
PASSWORD_REQUIRE_UPPERCASE=True

# 是否要求密码包含数字
PASSWORD_REQUIRE_DIGITS=True

# 是否要求密码包含特殊字符
PASSWORD_REQUIRE_SPECIAL=False

