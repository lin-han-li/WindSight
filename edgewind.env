# WindSight 环境变量配置（已激活）
# 说明：
# - 本文件会被 app.py 在启动时自动加载（python-dotenv）
# - 如需指定其它配置文件，可设置环境变量：WINDSIGHT_ENV_FILE
#
# 注意（生产环境）：
# - 请务必修改 SECRET_KEY
# - 请按需收紧 ALLOWED_ORIGINS（不要长期使用 *）

# ==================== 安全配置 ====================
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# ==================== 数据库配置 ====================
# 推荐保持默认：instance/wind_farm.db（与项目保持一致）
DATABASE_URL=sqlite:///instance/wind_farm.db

# ==================== 服务器配置 ====================
HOST=0.0.0.0
PORT=5000

# ==================== 跨域配置 ====================
ALLOWED_ORIGINS=*

# ==================== 数据保留配置 ====================
DATA_RETENTION_DAYS=30

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
LOG_FILE=logs/windsight.log

# ==================== 性能/超时配置 ====================
SOCKET_PING_INTERVAL=10
SOCKET_PING_TIMEOUT=20
DB_TIMEOUT=20

# ==================== 说明 ====================
# 旧版本的推送/波形参数已不再使用，WindSight 当前仅保留必要配置项。


