# WindSight 环境变量配置模板（推荐复制为 edgewind.env）
# 说明：
# - app.py 启动时会按优先级加载：WINDSIGHT_ENV_FILE > edgewind.env > .env
# - edgewind.env 属于本机私有配置文件，请勿提交到仓库（已加入 .gitignore）

# ==================== 安全配置 ====================
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# ==================== 默认管理员（首次启动自动创建）====================
# 未设置 WINDSIGHT_DEFAULT_ADMIN_PASSWORD 时，后端会生成随机密码并打印到日志
WINDSIGHT_DEFAULT_ADMIN_ENABLED=1
WINDSIGHT_DEFAULT_ADMIN_USERNAME=WindSight
# WINDSIGHT_DEFAULT_ADMIN_PASSWORD=请设置强密码

# ==================== 数据库配置 ====================
DATABASE_URL=sqlite:///instance/wind_farm.db

# ==================== 服务器配置 ====================
HOST=0.0.0.0
PORT=5000

# ==================== 跨域配置 ====================
ALLOWED_ORIGINS=*

# ==================== 数据保留配置 ====================
DATA_RETENTION_DAYS=30

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
LOG_FILE=logs/windsight.log

# ==================== 性能/超时配置 ====================
SOCKET_PING_INTERVAL=10
SOCKET_PING_TIMEOUT=20
DB_TIMEOUT=20


